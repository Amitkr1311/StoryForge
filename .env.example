# ─────────────────────────────────────────────────────────────
# StoryForge — Environment Variables
# ─────────────────────────────────────────────────────────────

# ── Flask ─────────────────────────────────────────────────────
FLASK_DEBUG=true
PORT=5000

# ── Free Image Providers ───────────────────────────────────────

# HuggingFace Inference API — FLUX.1-schnell (completely FREE)
# Get your free token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Google Gemini 3.1 Flash Lite Preview — image generation (needs billing for images)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Stability AI — SD 3.5 (25 free credits on sign-up)
# Get your key at: https://platform.stability.ai/account/keys
STABILITY_API_KEY=

# Stable Horde — FREE community Stable Diffusion (no key needed)
# Get a key at https://stablehorde.net for higher priority queue
STABLE_HORDE_KEY=

# ── LLM Image Prompt Enhancement (Optional) ────────────────────

# Gemini 3.1 Flash Lite Preview — used to supercharge prompts if the UI toggle is turned on
# It uses the GEMINI_API_KEY from above.
